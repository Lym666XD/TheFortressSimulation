{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://humanfortress.game/schemas/source.profession-catalog.schema.json",
  "title": "Profession registry source family",
  "type": "object",
  "required": ["professions"],
  "properties": {
    "professions": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/profession" }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "profession": {
      "type": "object",
      "required": ["id", "name", "job_tags"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
        "name": { "type": "string", "minLength": 1 },
        "job_tags": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "default": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  }
}
