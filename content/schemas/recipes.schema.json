{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://humanfortress.game/schemas/recipes.schema.json",
  "title": "Workshop Recipes Registry Schema",
  "description": "Schema for workshop/crafting recipes (data-driven, station-scoped, with tool/enabler gating).",
  "type": "object",
  "required": ["$schema", "version", "recipes"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "description": "Registry version (semver)"
    },
    "_comment": {
      "type": "string",
      "description": "Optional file-level comment"
    },
    "recipes": {
      "type": "array",
      "description": "Array of recipe definitions",
      "items": {
        "$ref": "#/definitions/Recipe"
      }
    }
  },
  "definitions": {
    "Recipe": {
      "type": "object",
      "required": ["id", "name", "category", "workshops", "work_time", "skill", "outputs", "unlock", "requirements"],
      "properties": {
        "_comment": { "type": "string", "description": "Optional comment for this recipe" },

        "id": {
          "type": "string",
          "pattern": "^core_recipe_[a-z0-9_]+$",
          "description": "Unique recipe ID (must start with 'core_recipe_')"
        },
        "name": { "type": "string", "description": "Display name" },

        "category": { "type": "string", "description": "UI category (e.g., smelting, stoneworks, tailoring)" },

        "workshops": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Allowed stations (construction/workshop IDs). Accepts 'core_construction_*' or 'core_workshop_*'"
        },

        "era": { "type": "string", "enum": ["C", "M", "R"], "description": "Single era gating: C/M/R" },
        "era_min": { "type": "string", "enum": ["C", "M", "R"], "description": "Minimum era gating (C/M/R)" },
        "era_max": { "type": "string", "enum": ["C", "M", "R"], "description": "Maximum era gating (C/M/R)" },

        "work_time": { "$ref": "#/definitions/WorkTime", "description": "Work time budget (ticks only)" },

        "skill": { "$ref": "#/definitions/SkillBlock", "description": "Primary skill, difficulty, XP" },

        "requirements": { "$ref": "#/definitions/Requirements", "description": "Enablers/power/fluids" },

        "inputs": {
          "type": "array",
          "items": { "$ref": "#/definitions/Ingredient" },
          "description": "Required inputs. Each element is either a direct item, a tag slot, or an alternative group"
        },

        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/Product" },
          "description": "Primary products (and optional byproducts)"
        },

        "unlock": {
          "$ref": "#/definitions/UnlockBlock",
          "description": "Autolearn or research gating"
        }
      },
      "allOf": [ { "if": { "anyOf": [ { "required": ["era_min"] }, { "required": ["era_max"] } ] }, "then": { "not": { "required": ["era"] } } } ]
    },

    "WorkTime": {
      "type": "object",
      "required": ["duration_ticks"],
      "properties": {
        "duration_ticks": { "type": "integer", "minimum": 1, "description": "Work duration in ticks" }
      }
    },

    "SkillBlock": {
      "type": "object",
      "required": ["primary", "difficulty", "xp_per_craft"],
      "properties": {
        "primary": { "type": "string", "description": "Primary skill id (e.g., construction, masonry, smithing)" },
        "difficulty": { "type": "integer", "minimum": 0, "description": "Relative difficulty for quality checks" },
        "xp_per_craft": { "type": "integer", "minimum": 0, "description": "XP granted per completed craft" }
      }
    },

    "Requirements": {
      "type": "object",
      "properties": {
        "enablers": { "type": "array", "items": { "type": "string" }, "description": "Attachment/enabler IDs required on the workshop" },
        "power_w": { "type": "integer", "minimum": 0, "description": "Continuous power required in watts" },
        "fluid_inputs": { "type": "array", "items": { "$ref": "#/definitions/FluidRequirement" }, "description": "Fluid inputs (ml/s)" }
      }
    },

    

    "FluidRequirement": {
      "type": "object",
      "required": ["id", "rate_ml_s"],
      "properties": {
        "id": { "type": "string", "description": "Fluid id (e.g., water, brine, acid)" },
        "rate_ml_s": { "type": "integer", "minimum": 1, "description": "Consumption rate in ml/s while working" }
      }
    },

    "Ingredient": {
      "type": "object",
      "oneOf": [
        { "$ref": "#/definitions/IngredientDirect" },
        { "$ref": "#/definitions/IngredientTag" },
        { "$ref": "#/definitions/IngredientAnyOf" }
      ]
    },

    "IngredientDirect": {
      "type": "object",
      "required": ["def_id", "count"],
      "properties": {
        "def_id": { "type": "string", "description": "Specific item definition id" },
        "count": { "type": "integer", "minimum": 1 },
        "consume": { "type": "boolean", "default": true, "description": "If false, acts as a tool that is not consumed" }
      }
    },

    "IngredientTag": {
      "type": "object",
      "required": ["tag", "count"],
      "properties": {
        "tag": { "type": "string", "description": "Tag selector for acceptable items (e.g., block, plank, ore_copper)" },
        "count": { "type": "integer", "minimum": 1 },
        "consume": { "type": "boolean", "default": true }
      }
    },

    "IngredientAnyOf": {
      "type": "object",
      "required": ["any_of"],
      "properties": {
        "any_of": {
          "type": "array",
          "minItems": 1,
          "items": {
            "oneOf": [ { "$ref": "#/definitions/IngredientDirect" }, { "$ref": "#/definitions/IngredientTag" } ]
          },
          "description": "Satisfy this ingredient slot with exactly one of the alternatives"
        }
      }
    },

    "Product": {
      "type": "object",
      "oneOf": [
        { "$ref": "#/definitions/ProductDirect" },
        { "$ref": "#/definitions/ProductInherited" }
      ]
    },

    "ProductDirect": {
      "type": "object",
      "required": ["def_id", "count"],
      "properties": {
        "def_id": { "type": "string", "description": "Specific item definition id" },
        "count": { "type": "integer", "minimum": 1 },
        "byproduct": { "type": "boolean", "default": false, "description": "True if this product is a byproduct" }
      }
    },

    "ProductInherited": {
      "type": "object",
      "required": ["template_def_id", "count", "inherit_material_from"],
      "properties": {
        "template_def_id": { "type": "string", "description": "Base item def; material/color inherited from input" },
        "count": { "type": "integer", "minimum": 1 },
        "inherit_material_from": {
          "type": "object",
          "required": ["mode"],
          "properties": {
            "mode": { "type": "string", "enum": ["first_input", "by_tag", "by_index"], "description": "Material inheritance strategy" },
            "tag": { "type": "string", "description": "When mode=by_tag: match this tag among inputs" },
            "index": { "type": "integer", "minimum": 0, "description": "When mode=by_index: input index to inherit from" }
          }
        },
        "byproduct": { "type": "boolean", "default": false }
      },
      "allOf": [
        {
          "if": { "properties": { "inherit_material_from": { "properties": { "mode": { "const": "by_tag" } } } } },
          "then": { "required": ["inherit_material_from"], "properties": { "inherit_material_from": { "required": ["mode", "tag"] } } }
        },
        {
          "if": { "properties": { "inherit_material_from": { "properties": { "mode": { "const": "by_index" } } } } },
          "then": { "required": ["inherit_material_from"], "properties": { "inherit_material_from": { "required": ["mode", "index"] } } }
        }
      ]
    },

    "UnlockBlock": {
      "type": "object",
      "properties": {
        "autolearn": { "type": "boolean", "default": false },
        "researched": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Research ids required to unlock"
        }
      }
    }
  }
}
