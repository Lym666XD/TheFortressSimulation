{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "material.authoring.v4.schema.json",
  "title": "Material Authoring Format",
  "description": "Human-readable authoring format for materials (string IDs, percentages)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "tags", "density_solid", "hardness_edge", "toughness_frac", "rigidity"],
    "properties": {
      "_comment": {
        "type": "string",
        "description": "Optional comment for organization"
      },
      "id": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$",
        "description": "String material ID (e.g., 'core_mat_metal_iron')"
      },
      "aliases": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "description": "Alternative names for backward compatibility"
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Material tags for categorization and behavior"
      },
      "density_solid": {
        "type": "number",
        "minimum": 0,
        "description": "Density in kg/m³"
      },
      "hardness_edge": {
        "type": "number",
        "minimum": 0,
        "maximum": 1000,
        "description": "Relative edge/cutting hardness"
      },
      "toughness_frac": {
        "type": "number",
        "minimum": 0,
        "maximum": 1000,
        "description": "Relative fracture toughness"
      },
      "rigidity": {
        "type": "number",
        "minimum": 0,
        "maximum": 1000,
        "description": "Relative material rigidity"
      },
      "electric_category": {
        "type": "string",
        "enum": ["conductor", "semi", "semiconductor", "insulator"],
        "description": "Electrical conductivity category"
      },
      "mana_conductivity": {
        "type": "number",
        "minimum": 0,
        "maximum": 1000,
        "description": "Relative magical conductivity"
      },
      "value_mul": {
        "type": "number",
        "minimum": 0,
        "description": "Economic value multiplier"
      },
      "beauty_mul": {
        "type": "number",
        "minimum": 0,
        "description": "Beauty value multiplier"
      },
      "work": {
        "type": "object",
        "properties": {
          "forgeable": {
            "type": "boolean",
            "description": "Can be forged"
          },
          "weldable": {
            "type": "boolean",
            "description": "Can be welded"
          },
          "carveable": {
            "type": "boolean",
            "description": "Can be carved"
          },
          "process_difficulty_mul": {
            "type": "number",
            "minimum": 0,
            "description": "Processing difficulty multiplier"
          }
        },
        "additionalProperties": false
      },
      "navigation": {
        "type": "object",
        "properties": {
          "move_cost_add": {
            "type": "number",
            "description": "Movement cost modifier"
          },
          "friction_mul": {
            "type": "number",
            "minimum": 0,
            "description": "Friction multiplier"
          },
          "hazard_level": {
            "type": "integer",
            "minimum": 0,
            "description": "Relative navigation hazard severity"
          },
          "hazard_type": {
            "type": "string",
            "minLength": 1,
            "description": "Stable symbolic navigation hazard category"
          }
        },
        "additionalProperties": false
      },
      "thermo": {
        "type": "object",
        "properties": {
          "ignition_point_c": {
            "type": "number",
            "description": "Ignition temperature in Celsius"
          },
          "melt_point_c": {
            "type": "number",
            "description": "Melting temperature in Celsius"
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
