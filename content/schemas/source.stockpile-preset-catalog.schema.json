{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://humanfortress.game/schemas/source.stockpile-preset-catalog.schema.json",
  "title": "Stockpile preset registry source family",
  "type": "array",
  "items": { "$ref": "#/definitions/preset" },
  "definitions": {
    "stringSet": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "idSet": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
      "uniqueItems": true
    },
    "preset": {
      "type": "object",
      "required": ["id", "name", "mode", "tags", "priority"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "mode": { "enum": ["Whitelist", "Blacklist"] },
        "tags": { "$ref": "#/definitions/stringSet" },
        "itemIds": { "$ref": "#/definitions/idSet" },
        "materials": { "$ref": "#/definitions/idSet" },
        "priority": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
