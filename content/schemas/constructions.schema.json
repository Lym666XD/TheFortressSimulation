{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://humanfortress.game/schemas/constructions.schema.json",
  "title": "Constructions Registry Schema",
  "description": "Schema for construction definitions (on-site built structures, quality always 0)",
  "type": "object",
  "required": ["$schema", "version", "category", "constructions"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "description": "Registry version (semver)"
    },
    "category": {
      "type": "string",
      "enum": ["walls", "floors", "stairs", "doors", "workshops", "defenses"],
      "description": "Construction category (determines file grouping)"
    },
    "_comment": {
      "type": "string",
      "description": "Optional file-level comment"
    },
    "constructions": {
      "type": "array",
      "description": "Array of construction definitions",
      "items": {
        "$ref": "#/definitions/Construction"
      }
    }
  },
  "definitions": {
    "Construction": {
      "type": "object",
      "required": ["id", "name", "category", "build_time_ticks", "material_costs", "placeable_profile"],
      "properties": {
        "_comment": {
          "type": "string",
          "description": "Optional comment for this construction"
        },
        "id": {
          "type": "string",
          "pattern": "^core_construction_[a-z0-9_]+$",
          "description": "Unique construction definition ID (must start with 'core_construction_')"
        },
        "name": {
          "type": "string",
          "description": "Display name (material-agnostic, e.g. 'Stone Wall')"
        },
        "category": {
          "type": "string",
          "description": "Primary category for UI grouping"
        },
        "result_material_id": {
          "type": "string",
          "minLength": 1,
          "description": "Optional geology material used for the completed structural terrain"
        },
        "build_time_ticks": {
          "type": "integer",
          "minimum": 1,
          "description": "Base construction time in ticks (modified by worker skill)"
        },
        "material_costs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/definitions/MaterialCost"
          },
          "description": "Required materials for construction"
        },
        "skill_required": {
          "type": "string",
          "description": "Optional skill tag (e.g. 'skill_masonry', 'skill_carpentry')"
        },
        "placeable_profile": {
          "$ref": "#/definitions/PlaceableProfile",
          "description": "Placeable properties (footprint, effects, passability)"
        }
      }
    },
    "MaterialCost": {
      "type": "object",
      "oneOf": [
        {
          "required": ["tag", "count"],
          "properties": {
            "tag": {
              "type": "string",
              "description": "Material tag (e.g. 'block', 'bar', 'log')"
            },
            "count": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of items required"
            }
          }
        },
        {
          "required": ["def_id", "count"],
          "properties": {
            "def_id": {
              "type": "string",
              "description": "Specific item definition ID (e.g. 'core_item_component_mechanism')"
            },
            "count": {
              "type": "integer",
              "minimum": 1,
              "description": "Number of items required"
            }
          }
        }
      ]
    },
    "PlaceableProfile": {
      "type": "object",
      "required": ["footprint", "passability", "requires_floor", "clearance_h", "blocks_light", "tags", "effects"],
      "properties": {
        "footprint": {
          "type": "object",
          "required": ["w", "d", "h"],
          "properties": {
            "w": {
              "type": "integer",
              "minimum": 1,
              "description": "Width (x-axis, tiles)"
            },
            "d": {
              "type": "integer",
              "minimum": 1,
              "description": "Depth (y-axis, tiles)"
            },
            "h": {
              "type": "integer",
              "minimum": 1,
              "description": "Height (z-axis, tiles)"
            }
          }
        },
        "passability": {
          "type": "string",
          "enum": ["blocking", "nonblocking", "doorway"],
          "description": "Pathfinding passability: blocking (wall-like), nonblocking (can walk through), doorway (requires door state)"
        },
        "requires_floor": {
          "type": "boolean",
          "description": "Whether this construction requires a floor tile beneath it"
        },
        "clearance_h": {
          "type": "integer",
          "minimum": 0,
          "description": "Required vertical clearance in tiles above the footprint"
        },
        "blocks_light": {
          "type": "boolean",
          "description": "Whether this construction blocks light propagation"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Tags for construction-specific filtering (e.g., 'workshop_masonry')"
        },
        "effects": {
          "$ref": "#/definitions/EffectsBlock",
          "description": "Environmental effects (fixed values, no quality modifier for constructions)"
        }
      }
    },
    "EffectsBlock": {
      "type": "object",
      "required": ["beauty", "comfort", "light_lumen", "heat_w"],
      "properties": {
        "beauty": {
          "type": "integer",
          "description": "Beauty value (discrete integer, can be negative)"
        },
        "comfort": {
          "type": "integer",
          "minimum": 0,
          "description": "Comfort value (discrete integer, non-negative)"
        },
        "light_lumen": {
          "type": "integer",
          "minimum": 0,
          "description": "Light output in lumens (discrete integer)"
        },
        "heat_w": {
          "type": "integer",
          "minimum": 0,
          "description": "Heat output in watts (discrete integer)"
        }
      }
    }
  }
}
