{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://humanfortress.game/schemas/source.terrain-kinds.schema.json",
  "title": "Active terrain-kind source family",
  "type": "object",
  "required": ["version", "terrainKinds", "terrainBitLayout"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "terrainKinds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "shape", "navigation"],
        "properties": {
          "id": { "type": "integer", "minimum": 0 },
          "name": { "type": "string", "minLength": 1 },
          "shape": { "type": "string", "minLength": 1 },
          "navigation": { "type": "object", "minProperties": 1 }
        },
        "additionalProperties": true
      }
    },
    "terrainBitLayout": {
      "type": "object",
      "required": ["totalBits", "fields"],
      "properties": {
        "totalBits": { "type": "integer", "minimum": 1 },
        "fields": { "type": "array", "minItems": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
