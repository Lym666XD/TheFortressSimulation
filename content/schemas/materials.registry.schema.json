{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "materials.registry.v4.schema.json",
  "title": "Materials Registry Format",
  "description": "Runtime format for materials (string IDs, FX integers)",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "tags", "density_solid", "mechanics"],
    "properties": {
      "_comment": {
        "type": "string",
        "description": "Optional comment for organization"
      },
      "id": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$",
        "description": "String material ID (e.g., 'core_mat_metal_iron')"
      },
      "aliases": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "description": "Alternative names for backward compatibility"
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "description": "Material tags for categorization and behavior"
      },
      "density_solid": {
        "type": "number",
        "minimum": 0,
        "description": "Density in kg/m³"
      },
      "mechanics": {
        "type": "object",
        "required": ["hardnessEdgeFx", "toughnessFracFx", "rigidityFx"],
        "properties": {
          "hardnessEdgeFx": {
            "type": "integer",
            "minimum": 0,
            "description": "Edge/cutting hardness (FX integer, 10000 = 100%)"
          },
          "toughnessFracFx": {
            "type": "integer",
            "minimum": 0,
            "description": "Fracture toughness (FX integer, 10000 = 100%)"
          },
          "rigidityFx": {
            "type": "integer",
            "minimum": 0,
            "description": "Material rigidity (FX integer, 10000 = 100%)"
          }
        },
        "additionalProperties": false
      },
      "electricMagic": {
        "type": "object",
        "properties": {
          "manaConductivityFx": {
            "type": "integer",
            "minimum": 0,
            "description": "Magical conductivity (FX integer, 10000 = 100%)"
          },
          "electricCategory": {
            "type": "string",
            "enum": ["conductor", "semiconductor", "insulator"],
            "description": "Electrical conductivity category"
          }
        },
        "additionalProperties": false
      },
      "economy": {
        "type": "object",
        "properties": {
          "valueMulFx": {
            "type": "integer",
            "minimum": 0,
            "description": "Economic value multiplier (FX integer, 10000 = 1.0x)"
          },
          "beautyMulFx": {
            "type": "integer",
            "minimum": 0,
            "description": "Beauty value multiplier (FX integer, 10000 = 1.0x)"
          }
        },
        "additionalProperties": false
      },
      "work": {
        "type": "object",
        "properties": {
          "forgeable": {
            "type": "boolean",
            "description": "Can be forged"
          },
          "weldable": {
            "type": "boolean",
            "description": "Can be welded"
          },
          "carveable": {
            "type": "boolean",
            "description": "Can be carved"
          },
          "processDifficultyMulFx": {
            "type": "integer",
            "minimum": 0,
            "description": "Processing difficulty multiplier (FX integer, 10000 = 1.0x)"
          }
        },
        "additionalProperties": false
      },
      "navigation": {
        "type": "object",
        "properties": {
          "moveCostAdd": {
            "type": "number",
            "description": "Movement cost modifier"
          },
          "frictionMulFx": {
            "type": "integer",
            "minimum": 0,
            "description": "Friction multiplier (FX integer, 10000 = 1.0x)"
          }
        },
        "additionalProperties": false
      },
      "thermo": {
        "type": "object",
        "properties": {
          "ignitionPointC": {
            "type": "number",
            "description": "Ignition temperature in Celsius"
          },
          "meltPointC": {
            "type": "number",
            "description": "Melting temperature in Celsius"
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }
}
