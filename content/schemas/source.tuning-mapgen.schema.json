{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://humanfortress.game/schemas/source.tuning-mapgen.schema.json",
  "title": "Active fortress map generation tuning",
  "description": "Mechanical contract for fortress surface elevation, hills, cave bands, and biome floors.",
  "type": "object",
  "required": ["surface", "hills", "bands", "biome_surface_floor"],
  "properties": {
    "surface": {
      "type": "object",
      "required": ["base_z", "sky_above"],
      "properties": {
        "base_z": { "type": "integer", "minimum": 1, "maximum": 49 },
        "sky_above": { "type": "integer", "minimum": 0, "maximum": 49 }
      },
      "additionalProperties": false
    },
    "hills": {
      "type": "object",
      "required": ["enabled", "radius_min", "radius_max", "density", "max_delta_z"],
      "properties": {
        "enabled": { "type": "boolean" },
        "radius_min": { "type": "integer", "minimum": 1 },
        "radius_max": { "type": "integer", "minimum": 1 },
        "density": { "type": "number", "minimum": 0, "maximum": 1 },
        "max_delta_z": { "type": "integer", "minimum": 0, "maximum": 48 }
      },
      "additionalProperties": false
    },
    "bands": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/band" }
    },
    "biome_surface_floor": {
      "type": "object",
      "required": ["Default"],
      "minProperties": 1,
      "propertyNames": { "type": "string", "minLength": 1 },
      "additionalProperties": { "$ref": "#/definitions/contentId" }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "contentId": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$"
    },
    "band": {
      "type": "object",
      "required": ["name", "z_min", "z_max", "caves"],
      "properties": {
        "name": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$" },
        "z_min": { "type": "integer", "minimum": 0, "maximum": 49 },
        "z_max": { "type": "integer", "minimum": 0, "maximum": 49 },
        "caves": {
          "type": "object",
          "required": ["density"],
          "properties": {
            "density": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
