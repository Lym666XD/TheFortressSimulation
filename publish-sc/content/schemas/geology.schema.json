{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "geology.schema.json",
  "type": "object",
  "required": ["id", "tags", "material", "terrain_bits", "display", "properties"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_]+$"
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    },
    "material": {
      "type": "string",
      "description": "Reference to material ID"
    },
    "terrain_bits": {
      "type": "object",
      "required": ["kind", "natural", "support_flag"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["SolidWall", "OpenWithFloor", "OpenNoFloor", "Ramp", "Slope", "StairsUp", "StairsDown", "StairsUD"]
        },
        "natural": {"type": "boolean"},
        "support_flag": {"type": "boolean"},
        "ramp_dir": {
          "type": "string",
          "enum": ["N", "E", "S", "W", "NE", "SW", "none"],
          "default": "none"
        }
      }
    },
    "display": {
      "type": "object",
      "required": ["glyph", "foreground", "background"],
      "properties": {
        "glyph": {"type": "integer", "minimum": 0, "maximum": 255},
        "foreground": {
          "type": "object",
          "required": ["r", "g", "b"],
          "properties": {
            "r": {"type": "integer", "minimum": 0, "maximum": 255},
            "g": {"type": "integer", "minimum": 0, "maximum": 255},
            "b": {"type": "integer", "minimum": 0, "maximum": 255}
          }
        },
        "background": {
          "type": "object",
          "required": ["r", "g", "b"],
          "properties": {
            "r": {"type": "integer", "minimum": 0, "maximum": 255},
            "g": {"type": "integer", "minimum": 0, "maximum": 255},
            "b": {"type": "integer", "minimum": 0, "maximum": 255}
          }
        },
        "autotile": {
          "type": "object",
          "properties": {
            "connect_groups": {"type": "array", "items": {"type": "string"}},
            "connects_to": {"type": "array", "items": {"type": "string"}},
            "variants": {
              "type": "object",
              "properties": {
                "solo": {"type": "integer"},
                "end_n": {"type": "integer"},
                "end_e": {"type": "integer"},
                "end_s": {"type": "integer"},
                "end_w": {"type": "integer"},
                "corner_ne": {"type": "integer"},
                "corner_se": {"type": "integer"},
                "corner_sw": {"type": "integer"},
                "corner_nw": {"type": "integer"},
                "straight_ns": {"type": "integer"},
                "straight_ew": {"type": "integer"},
                "tee_n": {"type": "integer"},
                "tee_e": {"type": "integer"},
                "tee_s": {"type": "integer"},
                "tee_w": {"type": "integer"},
                "cross": {"type": "integer"}
              }
            }
          }
        }
      }
    },
    "properties": {
      "type": "object",
      "properties": {
        "mineable": {"type": "boolean", "default": false},
        "buildable": {"type": "boolean", "default": false},
        "smoothable": {"type": "boolean", "default": false},
        "nav_cost_base": {"type": "integer", "default": 10},
        "opacity": {"type": "integer", "minimum": 0, "maximum": 100, "default": 0},
        "flammable": {"type": "boolean", "default": false},
        "layer_depth": {"type": "integer", "description": "Typical depth in geological layers"},
        "ore_chance": {"type": "number", "minimum": 0, "maximum": 1, "default": 0}
      }
    }
  }
}
