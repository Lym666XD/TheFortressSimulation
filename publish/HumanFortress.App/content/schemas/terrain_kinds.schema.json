{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Terrain Kinds Schema",
  "description": "Schema for terrain kind definitions (shapes/forms) in HumanFortress",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version (semver)"
    },
    "terrainKinds": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/terrainKind"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "terrainBitLayout": {
      "$ref": "#/definitions/bitLayout",
      "description": "Bit layout for TerrainBits field"
    }
  },
  "required": ["version", "terrainKinds", "terrainBitLayout"],
  "additionalProperties": false,

  "definitions": {
    "terrainKind": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 0,
          "maximum": 7,
          "description": "Terrain kind ID (0-7 for 3 bits)"
        },
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Canonical terrain kind name"
        },
        "description": {
          "type": "string",
          "description": "Human-readable description"
        },
        "shape": {
          "type": "string",
          "enum": ["solid", "floor", "empty", "ramp", "stairs", "chasm"],
          "description": "Basic shape category"
        },
        "navigation": {
          "$ref": "#/definitions/navigationRules"
        },
        "support": {
          "$ref": "#/definitions/supportRules"
        },
        "connectivity": {
          "$ref": "#/definitions/connectivityRules"
        },
        "allowedMaterials": {
          "type": "array",
          "items": {
            "type": "string",
            "description": "Material category or specific material"
          },
          "description": "Which materials can have this terrain kind"
        },
        "flags": {
          "$ref": "#/definitions/terrainFlags"
        }
      },
      "required": ["id", "name", "shape", "navigation"],
      "additionalProperties": false
    },

    "navigationRules": {
      "type": "object",
      "properties": {
        "walkable": {
          "type": "boolean",
          "description": "Can be walked on/through"
        },
        "standable": {
          "type": "boolean",
          "description": "Can support standing"
        },
        "climbable": {
          "type": "boolean",
          "description": "Can be climbed"
        },
        "flyable": {
          "type": "boolean",
          "description": "Can be flown through"
        },
        "blocksSight": {
          "type": "boolean",
          "description": "Blocks line of sight"
        },
        "blocksProjectiles": {
          "type": "boolean",
          "description": "Blocks projectile movement"
        },
        "blocksGas": {
          "type": "boolean",
          "description": "Blocks gas flow"
        },
        "blocksLiquid": {
          "type": "boolean",
          "description": "Blocks liquid flow"
        },
        "costMultiplier": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 10,
          "description": "Movement cost multiplier"
        },
        "requiresDirection": {
          "type": "boolean",
          "description": "Requires direction (ramps, stairs)"
        }
      },
      "required": ["walkable", "standable", "blocksSight"],
      "additionalProperties": false
    },

    "supportRules": {
      "type": "object",
      "properties": {
        "providesSupport": {
          "type": "boolean",
          "description": "Provides structural support"
        },
        "requiresSupport": {
          "type": "boolean",
          "description": "Requires support from below"
        },
        "lateralSupport": {
          "type": "boolean",
          "description": "Can provide lateral support"
        },
        "maxLoadAbove": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum load tiles above"
        },
        "collapseInto": {
          "type": "string",
          "description": "What terrain kind when support lost"
        }
      },
      "additionalProperties": false
    },

    "connectivityRules": {
      "type": "object",
      "properties": {
        "connectsHorizontal": {
          "type": "boolean",
          "description": "Forms horizontal connections"
        },
        "connectsVertical": {
          "type": "boolean",
          "description": "Forms vertical connections"
        },
        "connectsDiagonal": {
          "type": "boolean",
          "description": "Forms diagonal connections"
        },
        "allowsZTransition": {
          "type": "boolean",
          "description": "Allows Z-level transitions"
        },
        "transitionType": {
          "type": "string",
          "enum": ["none", "up", "down", "both"],
          "description": "Type of Z transition"
        }
      },
      "additionalProperties": false
    },

    "terrainFlags": {
      "type": "object",
      "properties": {
        "natural": {
          "type": "boolean",
          "description": "Natural terrain (not constructed)"
        },
        "smoothable": {
          "type": "boolean",
          "description": "Can be smoothed"
        },
        "engravable": {
          "type": "boolean",
          "description": "Can be engraved"
        },
        "buildable": {
          "type": "boolean",
          "description": "Can build on/in this terrain"
        },
        "removable": {
          "type": "boolean",
          "description": "Can be removed/deconstructed"
        },
        "replaceable": {
          "type": "boolean",
          "description": "Can be replaced by construction"
        }
      },
      "additionalProperties": false
    },

    "bitLayout": {
      "type": "object",
      "properties": {
        "totalBits": {
          "type": "integer",
          "enum": [16],
          "description": "Total bits in TerrainBits field"
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Field name"
              },
              "startBit": {
                "type": "integer",
                "minimum": 0,
                "maximum": 15
              },
              "bitCount": {
                "type": "integer",
                "minimum": 1,
                "maximum": 16
              },
              "description": {
                "type": "string"
              },
              "values": {
                "type": "object",
                "additionalProperties": {
                  "type": "integer"
                },
                "description": "Named values for this field"
              }
            },
            "required": ["name", "startBit", "bitCount"],
            "additionalProperties": false
          }
        }
      },
      "required": ["totalBits", "fields"],
      "additionalProperties": false
    }
  }
}