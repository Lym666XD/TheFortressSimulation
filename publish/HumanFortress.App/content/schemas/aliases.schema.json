{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Aliases Schema",
  "description": "Schema for material/terrain aliases and migrations",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Schema version (semver)"
    },
    "materialAliases": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/alias"
      },
      "description": "Material name aliases for backward compatibility"
    },
    "terrainAliases": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/alias"
      },
      "description": "Terrain kind aliases for backward compatibility"
    },
    "migrations": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/migration"
      },
      "description": "Content migrations between versions"
    }
  },
  "required": ["version"],
  "additionalProperties": false,

  "definitions": {
    "alias": {
      "type": "object",
      "properties": {
        "from": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Old name"
        },
        "to": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$",
          "description": "Current name"
        },
        "deprecatedVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Version when deprecated"
        },
        "removeVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Version when support will be removed"
        },
        "reason": {
          "type": "string",
          "description": "Reason for alias/deprecation"
        }
      },
      "required": ["from", "to"],
      "additionalProperties": false
    },

    "migration": {
      "type": "object",
      "properties": {
        "fromVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Source version"
        },
        "toVersion": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Target version"
        },
        "type": {
          "type": "string",
          "enum": ["rename", "split", "merge", "transform"],
          "description": "Migration type"
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/migrationRule"
          }
        },
        "description": {
          "type": "string",
          "description": "Migration description"
        }
      },
      "required": ["fromVersion", "toVersion", "type", "rules"],
      "additionalProperties": false
    },

    "migrationRule": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["material", "terrain", "property"],
          "description": "What is being migrated"
        },
        "action": {
          "type": "string",
          "enum": ["rename", "replace", "remove", "transform"],
          "description": "Migration action"
        },
        "source": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } }
          ],
          "description": "Source value(s)"
        },
        "target": {
          "oneOf": [
            { "type": "string" },
            { "type": "array", "items": { "type": "string" } },
            { "type": "object" }
          ],
          "description": "Target value(s)"
        },
        "transform": {
          "type": "object",
          "description": "Property transformations"
        },
        "condition": {
          "type": "object",
          "description": "Conditional migration rules"
        }
      },
      "required": ["type", "action", "source"],
      "additionalProperties": false
    }
  }
}